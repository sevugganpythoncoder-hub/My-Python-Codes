#REPOST
import json

def load_settings():
    try:
        with open("Save.json","r") as f:
            return json.load(f)
    except (FileNotFoundError,json.JSONDecodeError):
        return {"Class Batting/Bowling"}

def save_settings(Data):
    with open("Save.json","w") as f:
        json.dump(Data, f, indent=4)

Player = str(input("Would you like to ON the cricket system?[Y/N]")).upper()
if Player == "Y":
    ask = int(input("are you a bowler or batter?[type 1 or 2]:"))
    if ask == 1:
        name = input("Enter NAME:")
        player_stats = {"Wkts": 0,"Runs_conceded": 0,"Maidens" : 0,"Balls_Bowled" : 0}
        for i in player_stats:
            player_stats[i] = int(input(f"Enter the following info for {i}:"))
        player_stats["Name"] = name
        Decision = input("Would you like to view your current stats?[Y/N]").upper()
        if Decision == "Y":
            print(f"{player_stats["Name"]}'s stats are {player_stats}")
        else:
            print("Next step")
        if player_stats["Balls_Bowled"] == 0:
            print("INVALID")
        else:
            subs = player_stats["Runs_conceded"]
            subs2 = player_stats["Balls_Bowled"]
            economy = subs/subs2
            player_stats["Economy"] = economy
            print(f"\n FINAL STATS of {player_stats["Name"]} :{player_stats}")
            feedback = input("Did you have a good experience using MYCRICKET?[Y/N]").upper()
            if feedback == "Y":
                print("Thank you")
            else:
                print("We will further try to improve our site thank you!")
            Data = input("Would You like to save?[Y/N]")
            if Data == "Y":
                save_settings(player_stats)
                print("Successfully saved!")
            else:
                print("Moving On..")
    elif ask == 2:
        name = input("Enter NAME:")
        player_stats2 = {}
        runs = int(input("Runs_scored"))
        balls = int(input("Balls played"))
        player_stats2["Runs_scored:"] = runs
        player_stats2["Balls_Played:"] = balls
        player_stats2["name"] = name
        if balls == 0:
                print("INVALID")
        else:
            strike_rate = runs/balls * 100
            player_stats2["Strike_rate"] = strike_rate
            print(f"stats of {player_stats2["name"]} is {player_stats2}")
        feedback = input("Did you enjoy your experience using MYCRICKET?[Y/N]")
        if feedback == "Y":
            print("Thank you")
        else:
            print("We will further try to improve our site thank you!")
        Data2 = input("Would you like to save?[Y/N]")
        if Data2 == "Y":
            save_settings(player_stats2)
            print("successfully saved!")
        else:
            ("Moving On..")
elif Player == "N":
    print("System closing...")
else:
    print("Invaild Key")
